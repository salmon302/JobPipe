JOBPIPE_DB_PATH=data/jobpipe.db
JOBPIPE_MASTER_CV_PATH=Master_CV.md
JOBPIPE_JOB_DESCRIPTION_PATH=Job_Description.md
JOBPIPE_RESUME_OUTPUT_DIR=data/resume
JOBPIPE_RESUME_TARGET_BASENAME=Targeted_Resume
JOBPIPE_PDFLATEX_COMMAND=pdflatex
JOBPIPE_RESUME_COMPILE_RETRIES=2
JOBPIPE_RESUME_COMPILE_TIMEOUT_SECONDS=120
JOBPIPE_RESUME_WRITE_RETRIES=2
JOBPIPE_HIRINGCAFE_BASE_URL=https://hiring.cafe
JOBPIPE_HIRINGCAFE_STORAGE_STATE=data/session/hiringcafe_storage_state.json
JOBPIPE_HIRINGCAFE_HEADLESS=true
JOBPIPE_HIRINGCAFE_JITTER_MIN=1.5
JOBPIPE_HIRINGCAFE_JITTER_MAX=3.5
JOBPIPE_HIRINGCAFE_FETCH_DETAILS=true
JOBPIPE_WELLFOUND_ENABLED=false
JOBPIPE_WELLFOUND_BASE_URL=https://wellfound.com
JOBPIPE_WELLFOUND_STORAGE_STATE=data/session/wellfound_storage_state.json
JOBPIPE_WELLFOUND_HEADLESS=true
JOBPIPE_WELLFOUND_JITTER_MIN=1.5
JOBPIPE_WELLFOUND_JITTER_MAX=3.5
JOBPIPE_WELLFOUND_FETCH_DETAILS=true
JOBPIPE_BUILTIN_ENABLED=false
JOBPIPE_BUILTIN_BASE_URL=https://builtin.com
JOBPIPE_BUILTIN_STORAGE_STATE=data/session/builtin_storage_state.json
JOBPIPE_BUILTIN_HEADLESS=true
JOBPIPE_BUILTIN_JITTER_MIN=1.5
JOBPIPE_BUILTIN_JITTER_MAX=3.5
JOBPIPE_BUILTIN_FETCH_DETAILS=true
JOBPIPE_USER_AGENTS=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/135.0.0.0 Safari/537.36||Mozilla/5.0 (Windows NT 10.0; Win64; x64; rv:137.0) Gecko/20100101 Firefox/137.0
JOBPIPE_HIRINGCAFE_USER_AGENTS=
JOBPIPE_WELLFOUND_USER_AGENTS=
JOBPIPE_BUILTIN_USER_AGENTS=
JOBPIPE_CRITICAL_SKILLS=python,fastapi,sql,aws
JOBPIPE_REJECT_TERMS=senior,staff,principal,architect
JOBPIPE_USER_YEARS_EXPERIENCE=1
JOBPIPE_NOTIFICATION_THRESHOLD=0.80
JOBPIPE_AUTO_STAGE_JOB_DESCRIPTION=false
JOBPIPE_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
JOBPIPE_REQUIRE_USABLE_AUTH_STATE=false
JOBPIPE_SCHEDULE_INTERVAL_HOURS=2
JOBPIPE_RUN_LOCK_PATH=data/runtime/aggregator.lock
JOBPIPE_RUN_LOCK_STALE_SECONDS=21600
