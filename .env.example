# Purpose: Example environment configuration for JobPipe.
# Author: Seth Nenninger (GPT-5.2-Codex Agent)
# Timestamp: 2026-05-12T00:00:00Z
# Changelog: Replace scraper settings with ingest server configuration.

JOBPIPE_DB_PATH=data/jobpipe.db
JOBPIPE_MASTER_CV_PATH=Master_CV.md
JOBPIPE_JOB_DESCRIPTION_PATH=Job_Description.md
JOBPIPE_RESUME_OUTPUT_DIR=data/resume
JOBPIPE_RESUME_TARGET_BASENAME=Targeted_Resume
JOBPIPE_PDFLATEX_COMMAND=pdflatex
JOBPIPE_RESUME_COMPILE_RETRIES=2
JOBPIPE_RESUME_COMPILE_TIMEOUT_SECONDS=120
JOBPIPE_RESUME_WRITE_RETRIES=2
JOBPIPE_INGEST_HOST=127.0.0.1
JOBPIPE_INGEST_PORT=3838
JOBPIPE_INGEST_MAX_PAYLOAD_BYTES=1000000
# Critical skills: leave empty to disable skill filtering (allow all jobs)
# Examples: python,fastapi,sql,aws OR leave empty for general job search
JOBPIPE_CRITICAL_SKILLS=
# Reject terms: words that will cause a job to be rejected (checked in title + first 500 chars)
JOBPIPE_REJECT_TERMS=senior,staff,principal,architect,director
JOBPIPE_USER_YEARS_EXPERIENCE=1
JOBPIPE_NOTIFICATION_THRESHOLD=0.80
JOBPIPE_AUTO_STAGE_JOB_DESCRIPTION=false
JOBPIPE_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
JOBPIPE_RUN_LOCK_PATH=data/runtime/aggregator.lock
JOBPIPE_RUN_LOCK_STALE_SECONDS=21600
