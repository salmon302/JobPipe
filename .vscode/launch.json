{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "JobPipe: Ingest Server",
      "type": "debugpy",
      "request": "launch",
      "module": "jobpipe",
      "args": ["ingest-server"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true,
      "envFile": "${workspaceFolder}/.env",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src",
        "PYTHONEXECUTABLE": "py -3.14"
      }
    },
    {
      "name": "JobPipe: GUI",
      "type": "debugpy",
      "request": "launch",
      "module": "jobpipe",
      "args": ["gui"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true,
      "envFile": "${workspaceFolder}/.env",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src",
        "PYTHONEXECUTABLE": "py -3.14"
      }
    },
    {
      "name": "JobPipe: Top Jobs",
      "type": "debugpy",
      "request": "launch",
      "module": "jobpipe",
      "args": ["top", "--limit", "10"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true,
      "envFile": "${workspaceFolder}/.env",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src",
        "PYTHONEXECUTABLE": "py -3.14"
      }
    },
    {
      "name": "JobPipe: Init DB",
      "type": "debugpy",
      "request": "launch",
      "module": "jobpipe",
      "args": ["init-db"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true,
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src",
        "PYTHONEXECUTABLE": "py -3.14"
      }
    },
    {
      "name": "JobPipe: Runs",
      "type": "debugpy",
      "request": "launch",
      "module": "jobpipe",
      "args": ["runs"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true,
      "envFile": "${workspaceFolder}/.env",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src",
        "PYTHONEXECUTABLE": "py -3.14"
      }
    },
    {
      "name": "Debug tests (pytest)",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": ["-q"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": false,
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src"
      }
    },
    {
      "name": "Attach (debugpy)",
      "type": "debugpy",
      "request": "attach",
      "connect": {
        "host": "localhost",
        "port": 5678
      }
    }
  ]
}