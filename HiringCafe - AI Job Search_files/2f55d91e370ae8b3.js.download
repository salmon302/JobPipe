nsparentIcon,e.s(["ALL_EXCLUSION_REASON_CODES",0,v,"AppTrackerFAQ",0,[{title:"What is Application Tracker?",content:"Application Tracker is HiringCafe's free tool to help you keep track of your job applications. You can add jobs, track your progress, and write notes. It's 100% free and easy to use."},{title:"How does it work?",content:"When you save jobs on HiringCafe or mark them as applied, they will automatically appear in your Application Tracker. You can also move jobs between lists, add notes, and track your progress."},{title:"How is it different from saving jobs on a spreadsheet?",content:"Application Tracker is designed specifically for job applications. It's easy to use, and it's integrated with HiringCafe's job search. You can also add notes and track your progress."},{title:"Is it free?",content:"Yes! It's 100% free for job seekers to use."},{title:"Can companies see my Application Tracker?",content:"No, your Application Tracker is private and secure. Employers will never be able to see your account activity, including your Application Tracker."}],"DEGEN_MODE_REQUIRES_AUTH",0,!1,"EXCLUSION_REASON_CODES",0,y,"EncouragedToApplyGroupTypes",0,{"Military Veterans":"military_veterans","Fair Chance":"fair_chance"},"ListOfBenefits",0,{"Generous Paid Time Off":"generous_paid_time_off","Four Day Work Week":"four_day_work_week","401k Matching":"401k_matching","Generous Parental Leave":"generous_parental_leave","Retirement Plan":"retirement_plan","Tuition Reimbursement":"tuition_reimbursement","Visa Sponsorship":"visa_sponsorship","Relocation Assistance":"relocation_assistance"},"MochiFAQ",0,[{title:"What is HiringCafe Talent Network?",content:"Our talent network allows companies to reach out to you directly on HiringCafe. You can go live anytime, and you can hide your profile anytime. Your identity is always private and secure - companies are only able to access your personal information after you accept their intro request."},{title:"How does it work?",content:"After you submit your resume, our system will fetch your work experience and education (via ChatGPT's API) and make it available for companies. Your identity and contact information is only revealed when you accept their intro request. With HiringCafe, you'll never have to worry about spam or unsolicited messages."},{title:"Is it free?",content:"It's 100% free for job seekers, but not for companies 😅."},{title:"What information will be shared with companies?",content:"They'll be able to view your work experience, education history, salary expectation, and location preferences. Your name and contact information will remain hidden. They can access your identity if you decide to accept their intro request. You can reject their intro request anonymously. Your account activity such as intro requests, messages, jobs applied, profile views, and etc will always remain private and secure."},{title:"Can they see what jobs I've applied to?",content:"No, absolutely not. Your account activity is always private and secure and will never be shared with companies."},{title:"Can I hide my profile?",content:"Yes, you can hide your profile at any time. Simply toggle the switch in your account settings."},{title:"Can I hide my profile from specific companies?",content:"Yes, you can hide your profile from specific companies in your account settings."},{title:"Do I have to accept requests?",content:"No, you can accept or decline any number of requests. Your account will remain live until you hide your profile, and your account will not be affected by declining requests."},{title:"What do I need to do to join HiringCafe Talent Network?",content:"Just add your resume and your current location. If you want, you can add additional information (salary expectation, etc). It's really that simple! Behind the scenes, we'll use AI/ML/[insert other buzzwords here] to match you with the right companies."}],"OncallRequirementTypes",0,["None","Occasional (once a month or less)","Regular (once a week or more)"],"QUICK_SUMMARY_CARD_VIEW_FORMAT",0,{SAVED_LIST:"saved-list",SEARCH_RESULTS:"search-results"},"ShiftWorkRequirementTypes",0,["Required","Optional","Not Indicated"],"TravelRequirementTypes",0,["None","Minimal","Moderate","Extensive"],"applicationFormEaseOptions",0,["Simple","Time Consuming"],"cognitiveDemandLevelTypes",0,["Low","Medium","High"],"commitmentTypeOptions",0,["Full Time","Part Time","Contract","Internship","Temporary","Seasonal","Volunteer"],"computerUsageLevelTypes",0,["Low","Medium","High"],"educationRequirementTypes",0,["Required","Preferred","Not Mentioned"],"frequencyOptions",0,[{label:"Any",value:null},{label:"Hourly",value:"Hourly"},{label:"Daily",value:"Daily"},{label:"Weekly",value:"Weekly"},{label:"Bi-Weekly",value:"Bi-Weekly"},{label:"Monthly",value:"Monthly"},{label:"Yearly",value:"Yearly"}],"hideJobsOptions",0,["Hidden","Saved","Applied","Viewed"],"jobTypeMap",0,{FULL_TIME:"Full Time",PART_TIME:"Part Time",CONTRACT:"Contract",VOLUNTEER:"Volunteer"},"oralCommunicationLevelTypes",0,["Low","Medium","High"],"physicalLaborIntensityTypes",0,["Low","Medium","High"],"physicalPositionTypes",0,["Sitting","Standing"],"roleTypeOptions",0,["Individual Contributor","People Manager"],"securityClearanceTypes",0,["None","Confidential","Secret","Top Secret","Top Secret/SCI","Public Trust","Interim Clearances","Other"],"seniorityLevelTypes",0,["No Prior Experience Required","Entry Level","Mid Level","Senior Level"],"workplacePhysicalEnvironmentTypes",0,["Office","Outdoor","Vehicle","Industrial","Customer-Facing"],"workplaceTypeOptions",0,["Remote","Hybrid","Onsite"]],528781)}]);